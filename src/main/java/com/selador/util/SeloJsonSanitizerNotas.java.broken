package com.selador.util;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ArrayNode;
import com.fasterxml.jackson.databind.node.ObjectNode;

import java.math.BigDecimal;
import java.math.BigInteger;
import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.time.format.DateTimeParseException;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Map;

import com.selador.dao.ConnectionFactory;

/**
 * Utilitário para validar e sanitizar JSON de selos para o Tabelionato de Notas.
 * Implementa as regras de validação específicas para tipos de ato 401-459.
 * 
 *用法:
 * 
 * // Sanitizar JSON de selo
 * String jsonSanitizado = SeloJsonSanitizerNotas.sanitizar(jsonString);
 * 
 * // Validar e sanitizar com dados do banco
 * SeloJsonSanitizerNotas.ValidacaoResult result = SeloJsonSanitizerNotas.validarESanitizar(jsonString);
 * 
 * // Sanitizar e atualizar JSON12 no banco
 * SeloJsonSanitizerNotas.sanitizarESalvar(seloDigital);
 */
public class SeloJsonSanitizerNotas {

    private static final ObjectMapper M = new ObjectMapper();
    private static final DateTimeFormatter DATE_FORMAT = DateTimeFormatter.ofPattern("dd/MM/yyyy");
    private static final DateTimeFormatter DATE_FORMAT_ISO = DateTimeFormatter.ofPattern("yyyy-MM-dd");
    private static final java.util.logging.Logger LOGGER = java.util.logging.Logger.getLogger(SeloJsonSanitizerNotas.class.getName());
    
    // Tipos de ato válidos para o Tabelionato de Notas (TN1, TN2, TN3, TN5)
    private static final int[] TIPOS_ATO_VALIDOS = {
        401, 402, 403, 404, 405, // Autenticação e Reconhecimento de Firma
        406, 407, // Transferência de Veículo, Carta de Sentença
        408, 409, 410, 411, // Procuração, testamento, etc.
        412, 413, 414, 415, // Inventário, etc.
        416, 417, 418, 419, 420, // Constituição de Condomínio, Unidades
        421, 422, 423, 424, 425, 426, 427, 428, 429, // Páginas extras, Procuração, Pública Forma
        430, 431, 432, 433, 434, 435, 436, 437, // Traslado, etc.
        438, 439, 440, 441, 442, 443, 444, 445, 446, 447, 448, 449, // Diversos
        450, 451, 452, 453, 454, 455, 456, 457, 458, 459 // Diversos
    };
    
    // Buscar solicitante por num_rec na tabela fin_reccab
    private static ObjectNode buscarSolicitantePorNumRec(long numRec) {
        LOGGER.info("[SeloJsonSanitizerNotas] Buscando solicitante por numRec: " + numRec);
        
        Connection conn = null;
        PreparedStatement ps = null;
        ResultSet rs = null;
        
        try {
            conn = ConnectionFactory.getConnection();
            
            // Buscar dados do solicitante na tabela fin_reccab
            // O campo num_rec contém o número do registro
            String sql = "SELECT nomecli_rec, cpfcli_rec, tipodoccli_rec " +
                "FROM fin_reccab " +
                "WHERE num_rec = ?";
            
            ps = conn.prepareStatement(sql);
            ps.setLong(1, numRec);
            rs = ps.executeQuery();
            
            if (rs.next()) {
                ObjectNode solicitante = M.createObjectNode();
                
                String nomeRazao = rs.getString("nomecli_rec");
                String documentoNumero = rs.getString("cpfcli_rec");
                int tipoDoc = rs.getInt("tipodoccli_rec");
                
                // Se o tipo de documento não estiver definido, detectar pelo número
                if (tipoDoc == 0) {
                    tipoDoc = detectarTipoDocumento(documentoNumero);
                }
                
                solicitante.put("nomeRazao", nomeRazao != null ? nomeRazao : "");
                solicitante.put("documentoTipo", tipoDoc);
                solicitante.put("documentoNumero", documentoNumero != null ? documentoNumero : "");
                
                LOGGER.info("[SeloJsonSanitizerNotas] Solicitante encontrado: " + nomeRazao + ", documento: " + documentoNumero);
                return solicitante;
            } else {
                LOGGER.warning("[SeloJsonSanitizerNotas] Nenhum registro encontrado para numRec: " + numRec);
            }
            
        } catch (SQLException e) {
            LOGGER.severe("[SeloJsonSanitizerNotas] Erro ao buscar solicitante: " + e.getMessage());
        } finally {
            try { if (rs != null) rs.close(); } catch (SQLException e) {}
            try { if (ps != null) ps.close(); } catch (SQLException e) {}
            try { if (conn != null) conn.close(); } catch (SQLException e) {}
        }
        
        // Retornar objeto vazio se não encontrou
        ObjectNode solicitante = M.createObjectNode();
        solicitante.put("nomeRazao", "");
        solicitante.put("documentoTipo", 12); // Não Informado
        solicitante.put("documentoNumero", "");
        return solicitante;
    }
    
    // Stub: Detectar tipo de documento pelo número
    private static int detectarTipoDocumento(String numero) {
        if (numero == null || numero.isEmpty()) {
            return 12; // Não Informado
        }
        String num = numero.replaceAll("[^0-9]", "");
        if (num.length() == 11) {
            return 1; // CPF
        } else if (num.length() == 14) {
            return 2; // CNPJ
        }
        return 12; // Não Informado
    }

    /**
     * Extrai signatários do objeto selo procurando em campos comuns:
     * - propriedades.signatarios (se já existir)
     * - envolvidos (array)
     * - ListaPropriedades (mapeando envolvidos.*)
     */
    private static ArrayNode extrairSignatarios(ObjectNode seloObj) {
        ArrayNode signatarios = M.createArrayNode();
        java.util.Set<String> seen = new java.util.HashSet<>();

        // 1) Se já existe em propriedades.signatarios, retorna cópia
        if (seloObj.has("propriedades") && seloObj.get("propriedades").isObject()) {
            ObjectNode props = (ObjectNode) seloObj.get("propriedades");
            if (props.has("signatarios") && props.get("signatarios").isArray()) {
                ArrayNode arr = (ArrayNode) props.get("signatarios");
                for (JsonNode s : arr) {
                    if (s.isObject()) {
                        ObjectNode so = (ObjectNode) s;
                        String num = so.has("documentoNumero") ? so.get("documentoNumero").asText("") : "";
                        if (!num.isEmpty()) {
                            String key = num.replaceAll("[^0-9]", "");
                            if (!seen.contains(key)) {
                                seen.add(key);
                                signatarios.add(so);
                            }
                        }
                    }
                }
                if (signatarios.size() > 0) return signatarios;
            }
        }

        // 2) Extrair de 'envolvidos' quando existir
        if (seloObj.has("envolvidos") && seloObj.get("envolvidos").isArray()) {
            ArrayNode env = (ArrayNode) seloObj.get("envolvidos");
            for (JsonNode en : env) {
                if (en.isObject()) {
                    ObjectNode e = (ObjectNode) en;
                    String nome = null;
                    String num = null;
                    if (e.has("nomeRazao")) nome = e.get("nomeRazao").asText(null);
                    if (nome == null && e.has("nome")) nome = e.get("nome").asText(null);
                    if (e.has("documentoNumero")) num = e.get("documentoNumero").asText(null);
                    if (num == null && e.has("documento")) num = e.get("documento").asText(null);
                    if (num == null && e.has("CPF_CNPJ")) num = e.get("CPF_CNPJ").asText(null);
                    if (nome != null && num != null) {
                        String key = num.replaceAll("[^0-9]", "");
                        if (!seen.contains(key)) {
                            seen.add(key);
                            ObjectNode sign = M.createObjectNode();
                            sign.put("nomeRazao", nome);
                            sign.put("documentoTipo", detectarTipoDocumento(num));
                            sign.put("documentoNumero", num);
                            signatarios.add(sign);
                        }
                    }
                }
            }
        }

        // 3) Extrair de ListaPropriedades (várias convenções e possíveis erros de digitação)
        if (seloObj.has("ListaPropriedades") && seloObj.get("ListaPropriedades").isArray()) {
            ArrayNode listaProp = (ArrayNode) seloObj.get("ListaPropriedades");
            String ultimoNome = null;
            String ultimoNum = null;
            for (int i = 0; i < listaProp.size(); i++) {
                JsonNode item = listaProp.get(i);
                if (!item.isObject()) continue;
                ObjectNode it = (ObjectNode) item;
                String nomeProp = it.has("NomePropriedade") ? it.get("NomePropriedade").asText(null) : null;
                String valorProp = it.has("ValorPropriedade") && !it.get("ValorPropriedade").isNull() ? it.get("ValorPropriedade").asText(null) : null;
                if (nomeProp == null || valorProp == null) continue;

                String npLower = nomeProp.toLowerCase();
                if (npLower.contains("envolvid") || npLower.contains("envolv") || npLower.contains("emvolv")) {
                    if (npLower.contains("nome") || npLower.contains("razao") || npLower.contains("nome_razao")) {
                        ultimoNome = valorProp;
                    } else if (npLower.contains("cpf") || npLower.contains("cnpj") || npLower.contains("cpf_cnpj") || npLower.contains("documento")) {
                        ultimoNum = valorProp;
                    }
                    if (ultimoNome != null && ultimoNum != null) {
                        String key = ultimoNum.replaceAll("[^0-9]", "");
                        if (!seen.contains(key)) {
                            seen.add(key);
                            ObjectNode sign = M.createObjectNode();
                            sign.put("nomeRazao", ultimoNome);
                            sign.put("documentoTipo", detectarTipoDocumento(ultimoNum));
                            sign.put("documentoNumero", ultimoNum);
                            signatarios.add(sign);
                        }
                        ultimoNome = null;
                        ultimoNum = null;
                    }
                }
            }
        }

        return signatarios;
    }
    
    /**
     * Resultado da validação de um JSON de selo
     */
    public static class ValidacaoResult {
        public boolean valido;
        public List<String> erros = new ArrayList<>();
        public List<String> warnings = new ArrayList<>();
        public String jsonSanitizado;
        
        public static ValidacaoResult ok(String json) {
            ValidacaoResult r = new ValidacaoResult();
            r.valido = true;
            r.jsonSanitizado = json;
            return r;
        }
        
        public static ValidacaoResult erro(String erro) {
            ValidacaoResult r = new ValidacaoResult();
            r.valido = false;
            r.erros.add(erro);
            return r;
        }
        
        public static ValidacaoResult erro(List<String> erros) {
            ValidacaoResult r = new ValidacaoResult();
            r.valido = false;
            r.erros = erros;
            return r;
        }
    }

    /**
     * Sanitiza e salva o JSON12 no banco de dados para um selo específico.
     * Busca dados das tabelas do projeto e reconstruí o JSON corretamente.
     * 
     * @param seloDigital O número do selo digital
     * @return true se成功了, false caso contrário
     */
    public static boolean sanitizarESalvar(String seloDigital) {
        Connection conn = null;
        try {
            conn = ConnectionFactory.getConnection();
            
            // 1. Buscar o JSON atual do selados e parâmetros
            String sqlSelect = "SELECT sel.JSON, sel.JSON12, p.DTVERSAO_FUNARPEN, p.DOC_PAR " +
                "FROM selados sel " +
                "INNER JOIN parametros p ON p.CODIGO_PAR = 1 " +
                "INNER JOIN selos s ON sel.SELO = s.selo_sel " +
                "WHERE s.selo_sel = ?";
            
            String jsonAtual = null;
            String json12Atual = null;
            String dtVersaoFunarpen = null;
            String docPar = null;
            
            try (PreparedStatement ps = conn.prepareStatement(sqlSelect)) {
                ps.setString(1, seloDigital);
                try (ResultSet rs = ps.executeQuery()) {
                    if (rs.next()) {
                        jsonAtual = rs.getString("JSON");
                        json12Atual = rs.getString("JSON12");
                        dtVersaoFunarpen = rs.getString("DTVERSAO_FUNARPEN");
                        docPar = rs.getString("DOC_PAR");
                    }
                }
            }
            
            if (jsonAtual == null || jsonAtual.isEmpty()) {
                LOGGER.warning("[SeloJsonSanitizerNotas] JSON não encontrado para selo: " + seloDigital);
                return false;
            }
            
            // 2. Se já existe JSON12 válido, não precisa refazer
            if (json12Atual != null && !json12Atual.isEmpty()) {
                try {
                    JsonNode test = M.readTree(json12Atual);
                    if (test.isObject() && test.has("selo")) {
                        LOGGER.info("[SeloJsonSanitizerNotas] JSON12 já existe para selo: " + seloDigital);
                        return true;
                    }
                } catch (Exception e) {
                    // JSON12 inválido, vamos reconstruir
                }
            }
            
            // 3. Buscar dados complementares das tabelas
            Map<String, Object> dadosComplementares = buscarDadosComplementares(conn, seloDigital);
            
            // Adicionar o DOC_PAR aos dados complementares
            if (docPar != null && !docPar.isEmpty()) {
                dadosComplementares.put("DOC_PAR", docPar);
                LOGGER.info("[SeloJsonSanitizerNotas] DOC_PAR encontrado: " + docPar);
            }
            
            // 4. Sanitizar o JSON com os dados complementares
            String jsonSanitizado = sanitizarComDados(jsonAtual, dadosComplementares, dtVersaoFunarpen);
            
            // 5. Salvar no JSON12
            String sqlUpdate = "UPDATE selados sel " +
                "INNER JOIN selos s ON sel.SELO = s.selo_sel " +
                "SET sel.JSON12 = ? " +
                "WHERE s.selo_sel = ?";
            
            try (PreparedStatement ps = conn.prepareStatement(sqlUpdate)) {
                ps.setString(1, jsonSanitizado);
                ps.setString(2, seloDigital);
                ps.executeUpdate();
            }
            
            LOGGER.info("[SeloJsonSanitizerNotas] JSON sanitizado e salvo para selo: " + seloDigital);
            return true;
            
        } catch (Exception e) {
            LOGGER.severe("[SeloJsonSanitizerNotas] Erro ao sanitizar e salvar: " + e.getMessage());
            e.printStackTrace();
            return false;
        } finally {
            if (conn != null) {
                try {
                    conn.close();
                } catch (SQLException e) {
                    LOGGER.severe("Erro ao fechar conexão: " + e.getMessage());
                }
            }
        }
    }
    
